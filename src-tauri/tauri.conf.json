{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CyberFlow",
  "version": "0.1.0",
  "identifier": "com.zhanghuawei.cyberflow",
  "build": {
    "removeUnusedCommands": true,
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CyberFlow",
        "width": 1200,
        "height": 800,
        "minWidth": 1000,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "maximized": false,
        "center": true,
        "decorations": true,
        "alwaysOnTop": false,
        "transparent": false,
        "shadow": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' tauri: ipc: http://ipc.localhost"
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "createUpdaterArtifacts": true,
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "zhanghuawei",
    "category": "Productivity",
    "shortDescription": "A scriptable AI desktop assistant that automates your daily workflows.",
    "longDescription": "CyberFlow is a completely open, scriptable AI assistant for your desktop. It turns daily routines into automated, intelligent workflows through powerful LLM integrations and deep OS hooks.",
    "copyright": "Copyright © 2026 zhanghuawei. All rights reserved.",
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.15",
      "signingIdentity": "-",
      "providerShortName": null,
      "entitlements": null,
      "exceptionDomain": ""
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/frankz61/CyberFlow/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY3RjQ2NEQwNzMyMDQ2ODUKUldTRlJpQnowR1QwWitlam80dVA1SURWMkpQdm1ab0t3N3hlSlJFbSt6dFMzTFcxVjUrTEk2RU4K"
    }
  }
}
